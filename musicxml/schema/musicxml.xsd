			<xs:enumeration value="echo">
				<xs:annotation>
					<xs:documentation>&#xE81B;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="gyro">
				<xs:annotation>
					<xs:documentation>&#xE81D;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="hand martellato">
				<xs:annotation>
					<xs:documentation>&#xE812;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="mallet lift">
				<xs:annotation>
					<xs:documentation>&#xE816;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="mallet table">
				<xs:annotation>
					<xs:documentation>&#xE815;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="martellato">
				<xs:annotation>
					<xs:documentation>&#xE810;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="martellato lift">
				<xs:annotation>
					<xs:documentation>&#xE811;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="muted martellato">
				<xs:annotation>
					<xs:documentation>&#xE813;</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="pluck lift">
				<xs:annotation>
					<xs:documentation>&#xE817;</xs:documentation>
