	<xs:simpleType name="harmony-arrangement">
		<xs:annotation>
			<xs:documentation>The harmony-arrangement type indicates how stacked chords and bass notes are displayed within a harmony element. The vertical value specifies that the second element appears below the first. The horizontal value specifies that the second element appears to the right of the first. The diagonal value specifies that the second element appears both below and to the right of the first.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="vertical"/>
			<xs:enumeration value="horizontal"/>
			<xs:enumeration value="diagonal"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="harmony-type">
		<xs:annotation>
			<xs:documentation>The harmony-type type differentiates different types of harmonies when alternate harmonies are possible. Explicit harmonies have all notes present in the music; implied have some notes missing but implied; alternate represents alternate analyses.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="explicit">
				<xs:annotation>
					<xs:documentation>All notes present in the music.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="implied">
				<xs:annotation>
					<xs:documentation>Some notes are missing but implied.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="alternate">
				<xs:annotation>
					<xs:documentation>Alternate analysis.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="kind-value">
		<xs:annotation>
			<xs:documentation>A kind-value indicates the type of chord. Degree elements can then add, subtract, or alter from these starting points. The 11th and 13th values are usually used as a basis for alteration.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="major">
				<xs:annotation>
					<xs:documentation>Triad: major third, perfect fifth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor">
				<xs:annotation>
					<xs:documentation>Triad: minor third, perfect fifth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="augmented">
				<xs:annotation>
					<xs:documentation>Triad: major third, augmented fifth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="diminished">
				<xs:annotation>
					<xs:documentation>Triad: minor third, diminished fifth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="dominant">
				<xs:annotation>
					<xs:documentation>Seventh: major triad, minor seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="major-seventh">
				<xs:annotation>
					<xs:documentation>Seventh: major triad, major seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor-seventh">
				<xs:annotation>
					<xs:documentation>Seventh: minor triad, minor seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="diminished-seventh">
				<xs:annotation>
					<xs:documentation>Seventh: diminished triad, diminished seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="augmented-seventh">
				<xs:annotation>
					<xs:documentation>Seventh: augmented triad, minor seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="half-diminished">
				<xs:annotation>
					<xs:documentation>Seventh: diminished triad, minor seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="major-minor">
				<xs:annotation>
					<xs:documentation>Seventh: minor triad, major seventh.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="major-sixth">
				<xs:annotation>
					<xs:documentation>Sixth: major triad, added sixth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor-sixth">
				<xs:annotation>
					<xs:documentation>Sixth: minor triad, added sixth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="dominant-ninth">
				<xs:annotation>
					<xs:documentation>Ninth: dominant, major ninth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="major-ninth">
				<xs:annotation>
					<xs:documentation>Ninth: major-seventh, major ninth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor-ninth">
				<xs:annotation>
					<xs:documentation>Ninth: minor-seventh, major ninth.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="dominant-11th">
				<xs:annotation>
					<xs:documentation>11th: dominant-ninth, perfect 11th.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="major-11th">
				<xs:annotation>
					<xs:documentation>11th: major-ninth, perfect 11th.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor-11th">
				<xs:annotation>
					<xs:documentation>11th: minor-ninth, perfect 11th.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="dominant-13th">
