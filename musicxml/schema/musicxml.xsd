	<xs:simpleType name="numeral-mode">
		<xs:annotation>
			<xs:documentation>The numeral-mode type specifies the mode similar to the mode type, but with a restricted set of values. The different minor values are used to interpret &lt;numeral-root&gt; values of 6 and 7 when present in a minor key. The harmonic minor value sharpens the 7 and the melodic minor value sharpens both 6 and 7. If a minor mode is used without qualification, either in the &lt;mode&gt; or &lt;numeral-mode&gt; elements, natural minor is used.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="major">
				<xs:annotation>
					<xs:documentation>Numerals are interpreted relative to a major scale.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="minor">
				<xs:annotation>
					<xs:documentation>Numerals are interpreted relative to a natural minor scale.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="natural minor">
				<xs:annotation>
					<xs:documentation>Numerals are interpreted relative to a natural minor scale.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="melodic minor">
				<xs:annotation>
					<xs:documentation>Numerals are interpreted relative to an ascending melodic minor scale with raised 6th and 7th degrees.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="harmonic minor">
				<xs:annotation>
					<xs:documentation>Numerals are interpreted relative to a harmonic minor scale with a raised 7th degree.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="on-off">
		<xs:annotation>
			<xs:documentation>The on-off type is used for notation elements such as string mutes.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="on"/>
			<xs:enumeration value="off"/>
		</xs:restriction>
	</xs:simpleType>

	<xs:simpleType name="pedal-type">
		<xs:annotation>
			<xs:documentation>The pedal-type distinguishes types of pedal directions.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="start">
				<xs:annotation>
					<xs:documentation>Indicates the start of a damper pedal.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="stop">
				<xs:annotation>
					<xs:documentation>Indicates a pedal lift without a retake.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="sostenuto">
				<xs:annotation>
					<xs:documentation>Indicates the start of a sostenuto pedal.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="change">
				<xs:annotation>
					<xs:documentation>Indicates a pedal lift and retake indicated with an inverted V marking. Used when the &lt;pedal&gt; line attribute is yes.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="continue">
				<xs:annotation>
					<xs:documentation>Allows more precise formatting across system breaks and for more complex pedaling lines. Used when the &lt;pedal&gt; line attribute is yes.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="discontinue">
				<xs:annotation>
					<xs:documentation>Indicates the end of a pedal line that does not include the explicit lift represented by the stop type. Used when the &lt;pedal&gt; line attribute is yes.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
			<xs:enumeration value="resume">
				<xs:annotation>
					<xs:documentation>Indicates the start of a pedal line that does not include the downstroke represented by the start type. It can be used when a line resumes after being discontinued, or to start a pedal line that is preceded by a text or symbol representation of the pedal. Used when the &lt;pedal&gt; line attribute is yes.</xs:documentation>
				</xs:annotation>
			</xs:enumeration>
		</xs:restriction>
	</xs:simpleType>

